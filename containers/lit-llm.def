Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.02-py3

%labels
    Author gabe
    Description "GPU-enabled image for Qwen3 + vLLM serving (lit-llm)"

%post
    set -e
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        build-essential
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    python -m pip install --no-cache-dir --upgrade pip
    python -m pip install --no-cache-dir \
        vllm \
        loguru \
        fastapi \
        uvicorn

%environment
    export PYTHONUNBUFFERED=1
    export HF_HOME=/tmp/hf-cache

%runscript
    echo "Example vLLM launch inside container:"
    echo "  vllm serve /workspace/model-weights \\"
    echo "      --port 8000 \\"
    echo "      --max-model-len 131072 \\"
    echo "      --reasoning-parser qwen3 \\"
    echo "      --trust-remote-code"

