FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

LABEL maintainer="gabe" \
      description="GPU image for auto_lit_search: Qwen3 + vLLM + FastAPI server (slim)"

RUN set -e && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-dev python3-pip python3-venv git curl ca-certificates build-essential && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Same multi-interpreter strategy as Dockerfile.docling (see comments there).
RUN set -e; \
    _seen=""; \
    install_one() { \
      "$1" -m pip install --no-cache-dir --upgrade pip && \
      "$1" -m pip install --no-cache-dir \
        torch --index-url https://download.pytorch.org/whl/cu121 && \
      "$1" -m pip install --no-cache-dir \
        vllm \
        loguru \
        fastapi \
        uvicorn[standard] \
        requests; \
    }; \
    for cand in $(command -v python3 2>/dev/null || true) /usr/bin/python3 /usr/local/bin/python3; do \
      [ -n "$cand" ] && [ -x "$cand" ] || continue; \
      rp=$$(readlink -f "$$cand" 2>/dev/null || echo "$$cand"); \
      case "$$_seen" in *"|$$rp|"*) continue ;; esac; \
      _seen="$${_seen}|$$rp|"; \
      install_one "$$cand"; \
    done; \
    [ "$$_seen" != "" ] || (echo "No python3 executable found" >&2; exit 1)

RUN python3 -c "import uvicorn"

ENV PYTHONUNBUFFERED=1 \
    HF_HOME=/tmp/hf-cache

WORKDIR /app

# Repo code will be bind-mounted at runtime on the cluster; no COPY here by default.
CMD ["bash", "-lc", "echo 'Use gpu_llm_node.slurm to start vLLM + gpu_server'"]

